            </div>
        </div>

        <div class="testimonial-section mt-5 pt-5" data-aos="fade-up" data-aos-delay="100">
            <div class="row">
                <div class="col-lg-4" data-aos="fade-right" data-aos-delay="200">
                    <div class="testimonial-intro">
                        <h3>{{strategyclientstestimonial.[0].titulo}}</h3>
                        <p>{{{strategyclientstestimonial.[0].descripcion}}}</p>

                        <div class="swiper-nav-buttons mt-4">
                            <button class="slider-prev"><i class="bi bi-arrow-left"></i></button>
                            <button class="slider-next"><i class="bi bi-arrow-right"></i></button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8" data-aos="fade-left" data-aos-delay="300">
                    <div class="testimonial-slider swiper init-swiper">
                        <script type="application/json" class="swiper-config">
                  {
                    "loop": true,
                    "speed": 800,
                    "autoplay": {
                      "delay": 5000
                    },
                    "slidesPerView": 1,
                    "spaceBetween": 30,
                    "navigation": {
                      "nextEl": ".slider-next",
                      "prevEl": ".slider-prev"
                    },
                    "breakpoints": {
                      "768": {
                        "slidesPerView": 2
                      }
                    }
                  }
                </script>
                        <div class="swiper-wrapper">
                            {{#each strategyclientstestimonialcards}}
                            <div class="swiper-slide">
                                <div class="testimonial-item">
                                    <div class="rating mb-3">
                                        {{{renderStars stars}}}
                                    </div>
                                    <p>{{{ descripcion }}}</p>
                                    <div class="client-info d-flex align-items-center mt-4">
                                        <img src="{{img}}" class="client-img" alt="{{titulo_img}}" loading="lazy">
                                        <div>
                                            <h6 class="mb-0">{{titulo_img}}</h6>
                                            <span>{{sub_titulo_img}}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        </div>


