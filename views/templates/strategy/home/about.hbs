                    <div class="row g-4 mt-3">
                        {{#each strategyaboutusfeature}}
                        <div class="col-md-6" data-aos="zoom-in" data-aos-delay="400">
                            <div class="feature-item">
                                <i class="{{icon}}"></i>
                                <h5>{{titulo}}</h5>
                                <p>{{{ descripcion }}}</p>
                            </div>
                        </div>
                        {{/each}}
                    </div>

                    <a href="#" class="btn btn-primary mt-4">{{{ strategyabout.[0].btn_action }}}</a>
