<section class="space-1 wnr-bg01">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-title-center mb-55 mb-xs-35">
                    <span class="wnr-section-subtitle wow fadeInUp">{{solvatechservices.[0].subtitulo}}</span>
                    <h2 class="wnr-section-title mb-25 mb-xs-20 title-animation wow fadeInUp" data-wow-delay=".3s">
                        {{solvatechservices.[0].titulo}}</h2>
                </div>
            </div>
        </div>
        <div class="service-activation slick-wrapper--10 wnr-slick-dots wnr-slick-arrow arrow-between">

            {{#each solvatechservicescards}}
            <div class="slick-single-slide">
                <div class="service-card-wrap">
                    <div class="service-card-inner">
                        <div class="service-icon">
                            <i class="{{icon}}"></i>
                        </div>
                        <div class="service-content">
                            <h6 class="title">
                                <a href="">{{titulo}}</a>
                            </h6>
                            <p class="text">{{subtitulo}}</p>
                            <a href="solvatechservicescards/{{ id }}" class="wnr-btn btn-secondary btn-link btn-underlined read-btn">
                                <span>Read More</span>
                                <i class="unicon-arrow-up-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}

        </div>
    </div>
</section><!-- end .services-->