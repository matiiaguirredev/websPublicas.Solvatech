<section class="project space-1 wnr-bg01">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-title-center mb-40 mb-xs-35">
                    <span class="wnr-section-subtitle wow fadeInUp">{{ solvatechportfolio.[0].subtitulo }}</span>
                    <h2 class="wnr-section-title mb-25 mb-xs-20 title-animation wow fadeInUp" data-wow-delay=".3s">{{
                        solvatechportfolio.[0].titulo }}</h2>
                </div>
            </div>
        </div>
        <div class="project-tab masonary-menu">
            <button data-filter="*" class="active">All</button>
            {{#each solvatechservicescards}}
            <button data-filter=".c{{id}}">{{titulo}}</button>
            {{/each}}
        </div>

        <div class="projects-wrap">
            <div class="row grid wow fadeInUp">
                {{#each solvatechportfoliocards}}
                <div class="col-lg-4 col-sm-6 grid-item {{#each (split servicios ',')}}c{{this}} {{/each}}">
                    <div class="project-item-wrap">
                        <div class="project-inner">
                            <div class="project-media">
                                <img src="{{img}}" alt="{{titulo}}">
                            </div>
                            <div class="project-text">
                                <h6 class="title"><a href="javascript:;">{{titulo}}</a></h6>
                                <span class="location"><i class="bi bi-geo-alt"></i> {{ubicacion}}</span>
                            </div>
                            <div class="project-hover-content">
                                <h6 class="title"><a href="javascript:;">{{titulo}}</a></h6>
                                <p class="text">{{{descripcion}}}</p>
                                <a href="{{img}}" class="project-icon popup-image">
                                    <i class="icon-ui-plus"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

    </div>
</section><!-- end .portfolio-->