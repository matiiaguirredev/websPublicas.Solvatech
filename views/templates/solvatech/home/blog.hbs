<section class="space-1">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-title-center mb-55 mb-xs-35">
                    <span class="wnr-section-subtitle wow fadeInUp">{{solvatechblog.[0].subtitulo}}</span>
                    <h2 class="wnr-section-title mb-25 mb-xs-20 wow fadeInUp" data-wow-delay=".3s">
                        {{solvatechblog.[0].titulo}}</h2>
                </div>
            </div>
        </div>

        <div class="blog-activation slick-wrapper--10 wnr-slick-dots wnr-slick-arrow arrow-between">
            {{#each solvatechblogcards}}
            <div class="slick-single-slide">
                <div class="blog-wrap">
                    <div class="item-inner">

                        <div class="media-box">
                            <div class="media">
                                <a href="javascript:;">
                                    <img src="{{img}}" alt="{{titulo}}">
                                    <img src="{{img}}" alt="{{titulo}}">
                                </a>
                            </div>

                            {{!-- Fecha dinámica --}}
                            {{{formatDate fecha "es"}}}

                        </div>

                        <div class="content-box">
                            <ul class="post-meta">
                                <li>
                                    <i class="unicon-user"></i>
                                    By
                                    {{#each ../solvatechteamcards}}
                                    {{#if (eq this.id ../autor)}}
                                    {{this.titulo}}
                                    {{/if}}
                                    {{/each}}
                                </li>
                                <li><i class="unicon-message-circle"></i>Comments (0)</li>
                            </ul>

                            <h4 class="title">
                                <a href="javascript:;">{{titulo}}</a>
                            </h4>

                            <a href="solvatechblogcards/{{ id }}" class="wnr-btn btn-secondary btn-link btn-underlined read-more">
                                <span>Read More</span>
                                <i class="unicon-arrow-up-right"></i>
                            </a>
                        </div>

                    </div>
                </div>
            </div>
            {{/each}}
        </div>

    </div>
</section><!-- end .blog-->