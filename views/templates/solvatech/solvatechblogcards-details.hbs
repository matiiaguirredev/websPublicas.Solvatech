{{> solvatech/header }}
{{> solvatech/navbar }}

{{> solvatech/sectionBanners }}

<main>
    <section class="space-1">
        <div class="container">
            <div class="row">
                <div class="col-xl-8 col-lg-8">
                    <div class="wnr-blog-details-area">
                        <div class="single-post-wrap">
                            <div class="single-post-head">
                                <div class="single-post-thumbnail"><img src="{{solvatechblogcards.img}}"
                                        alt="Blog Images"></div>
                                <div class="single-post-meta">
                                    <ul class="post-meta-list">
                                        <li>
                                            <i class="icon-ui-user"></i>
                                            By
                                            {{solvatechblogcards.autor_rel.titulo}}
                                        </li>
                                        <li><i class="icon-ui-comments"></i>Comments (04)</li>
                                        <li><i class="icon-ui-calendar-days"></i>{{{formatDateBlog
                                            solvatechblogcards.fecha "es"}}}</li>
                                    </ul>
                                </div>
                                <div class="single-post-title">
                                    {{!-- <h1 class="post-title">{{solvatechblogcards.titulo}}</h1> --}}
                                </div>
                            </div>

                            <div class="single-post-content">

                                {{{ solvatechblogcards.descripcion }}}

                                <div class="post-share-wrap m-t30">
                                    <div class="post-tag">
                                        <h4 class="share-title">Tags:</h4>
                                        <div class="tag-list">
                                            {{#each solvatechblogcards.tags_rel}}
                                            <a href="javascript:;">{{titulo}}</a>
                                            {{/each}}
                                        </div>
                                    </div>

                                    {{!-- esto queda ver donde vamos a cargar las redes sociales del propio sitio --}}
                                    <div class="social-share">
                                        <h4 class="share-title">Share:</h4>
                                        <ul class="social-icon social-media transparent-border">
                                            <li><a href="javascript:;"><i class="icon-ui-facebook"></i></a></li>
                                            <li><a href="javascript:;"><i class="icon-ui-instagram"></i></a></li>
                                            <li><a href="javascript:;"><i class="icon-ui-twitter"></i></a></li>
                                            <li><a href="javascript:;"><i class="icon-ui-linkedin"></i></a></li>
                                        </ul>
                                    </div>
                                </div>
                                <!-- end .post-share-wrap-->

                                <div class="author-wrap">
                                    <div class="author-thumb"><img src="{{solvatechblogcards.autor_rel.img}}"
                                            alt="Blog Author"></div>
                                    <div class="author-content">
                                        <h4 class="author-title">{{solvatechblogcards.autor_rel.titulo}}</h4>
                                        <div class="author-designation">{{solvatechblogcards.autor_rel.puesto}}</div>
                                        <p class="author-desc">No tienen descripcion aun los team cards</p>

                                        {{{renderSocialLinks solvatechblogcards.autor_rel}}}

                                    </div>
                                </div>
                                <!-- end .blog author-->

