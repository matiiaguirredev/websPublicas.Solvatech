                </div>
                <div class="col-xl-4">
                    <aside class="wnr-sidebar-area sidebar-sticky">
                        <div class="widget-sidebar">
                            <div class="widget-inner">
                                <div class="widget-title">
                                    {{!-- queda hacer la funcionalidad de search --}}
                                    <h3>Search</h3>
                                </div>
                                <div class="widget-search">
                                    <form class="search-form" method="post" action="">
                                        <div class="input-box">
                                            <input type="text" name="search" placeholder="Enter Keyword">
                                            <button type="submit" class="search-icon"><i
                                                    class="icon-search"></i></button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        {{#if solvatechservicescards}}
                        <div class="widget-sidebar">
                            <div class="widget-inner">
                                <div class="widget-title">
                                    <h3>Categories</h3>
                                </div>
                                <div class="widget-categories">
                                    <ul class="widget-category-list">
                                        {{#each solvatechservicescards}}
                                        <li>
                                            <a href="/services">
                                                {{titulo}}
                                                <span class="arrow-icon"><i class="unicon-arrow-up-right"></i></span>
                                            </a>
                                        </li>
                                        {{/each}}
                                    </ul>
                                </div>
                            </div>
                        </div>
                        {{/if}}

                        {{#if recent_posts}}
                        <div class="widget-sidebar">
                            <div class="widget-inner">
                                <div class="widget-title">
                                    <h3>Recent Posts</h3>
                                </div>
                                <div class="widget-post">
                                    <ul class="widget-post-list">
                                        {{#each recent_posts}}
                                        <li>
                                            <div class="widget-post-thumbnail">
                                                <a href="/solvatechblogcards/{{id}}">
                                                    <img src="{{img}}" alt="{{titulo}}">
                                                </a>
                                            </div>
                                            <div class="widget-post-content">
                                                <h4 class="widget-post-title">
                                                    <a href="/solvatechblogcards/{{id}}">{{titulo}}</a>
                                                </h4>
                                                <div class="widget-post-meta">
                                                    <i class="bi bi-clock"></i>
                                                    <span class="widget-post-date">{{{formatDate fecha "en"}}}</span>
                                                </div>
                                            </div>
                                        </li>
                                        {{/each}}
                                    </ul>
                                </div>
                            </div>
                        </div>
                        {{/if}}


                        <div class="widget-sidebar">
                            <div class="widget-inner">
                                <div class="widget-title">
                                    <h3>Popular Tags</h3>
                                </div>
                                <div class="widget-tags">
                                    <div class="widget-tag-list">
                                        {{#each solvatechtags}}
                                        <a href="javascript:;">{{titulo}}</a>
                                        {{/each}}
                                    </div>
                                </div>

                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section><!-- end .blog details-->
</main>


{{> solvatech/footer }}