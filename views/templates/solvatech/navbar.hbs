<div id="wnr-preloader">
    <div class="loading-wrap">
        <div class="loading"></div>
        <div class="loading-logo">
            <img src="{{assetBase}}/assets/images/logo/logo-icon-white.png" class="logo" alt="logo">
            <img src="{{assetBase}}/assets/images/logo/logo-icon-white.png" class="logo-white" alt="logo">
        </div>
    </div>
</div><!-- end .preloader-->

<div id="percentage-scroll"><span id="percentage-scroll-value"></span></div>
<!-- end .backtotop-->

<div class="info-offcanvas">
    <div class="offcanvas-info">
        <div class="offcanvas-wrap">
            <div class="offcanvas__content">
                <div class="offcanvas__top mb-5 d-flex justify-content-between align-items-center">
                    <div class="offcanvas-logo">
                        <a href="/">
                            <img src="{{assetBase}}/assets/images/logo/logo.png" class="logo" alt="logo">
                            <img src="{{assetBase}}/assets/images/logo/logo-white.png" class="logo-white" alt="logo">
                        </a>
                    </div>
                    <div class="close-btn"><i class="bi bi-x-lg"></i></div>
                </div>
                <h3 class="offcanvas-title">About Us</h3>
                <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Sunt, laboriosam porro eius nam inventore
                    vitae.</p>

                <div class="offcanvas-social-area">
                    <h3 class="offcanvas-title">Follow Us</h3>
                    <ul class="social-icon social-media">
                        <li><a href="javascript:;"><i class="icon-ui-facebook"></i></a></li>
                        <li><a href="javascript:;"><i class="icon-ui-twitter"></i></a></li>
                        <li><a href="javascript:;"><i class="icon-ui-instagram"></i></a></li>
                        <li><a href="javascript:;"><i class="icon-ui-linkedin"></i></a></li>
                    </ul>
                </div>
                <div class="offcanvas-contact">
                    <h3 class="offcanvas-title">Contact Info</h3>
                    <ul class="contact-list">
                        <li>
                            <div class="contact-icon"><i class="bi bi-telephone"></i></div>
                            <div class="contact-content">
                                <h4 class="contact-title">Call Us</h4>
                                <div class="contact-text"><a href="tel:+12025550918">+1202-555-0918</a></div>
                            </div>
                        </li>
                        <li>
                            <div class="contact-icon"><i class="bi bi-envelope"></i></div>
                            <div class="contact-content">
                                <h4 class="contact-title">Email</h4>
                                <div class="contact-text"><a href="mailto:info@example.com">info@example.com</a></div>
                            </div>
                        </li>
                        <li>
                            <div class="contact-icon"><i class="bi bi-geo-alt"></i></div>
                            <div class="contact-content">
                                <h4 class="contact-title">Address</h4>
                                <div class="contact-text">
                                    <p>7253 Alva Flats, Michigan, USA</p>
                                </div>
                            </div>
                        </li>
                        <li>
                            <div class="contact-icon"><i class="bi bi-clock"></i></div>
                            <div class="contact-content">
                                <h4 class="contact-title">Opening Hours</h4>
                                <div class="contact-text">
                                    <p>10:00 - 19:00</p>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="offcanvas-overlay"></div>
</div><!-- end .offcanvas info-->

<div class="search__popup">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="search__wrapper">
                    <div class="search__close">
                        <button type="button" class="search-close-btn">
                            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"
                                xmlns="http://www.w3.org/2000/svg">
                                <path d="M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                <path d="M1 1L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </button>
                    </div>
                    <div class="search__form">
                        <form action="">
                            <div class="search__input">
                                <input class="search-input-field" type="text" placeholder="Type keywords here">
                                <span class="search-focus-border"></span>
                                <button>
                                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
                                        xmlns="http://www.w3.org/2000/svg">
                                        <path
                                            d="M9.55 18.1C14.272 18.1 18.1 14.272 18.1 9.55C18.1 4.82797 14.272 1 9.55 1C4.82797 1 1 4.82797 1 9.55C1 14.272 4.82797 18.1 9.55 18.1Z"
                                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                            stroke-linejoin="round"></path>
                                        <path d="M19.0002 19.0002L17.2002 17.2002" stroke="currentColor"
                                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                    </svg>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="search-popup-overlay"></div>
<!-- end .header-search-->

<header class="header_area site__header">
    <div class="header_wrapper" id="header-sticky">
        <div class="header-wrapper container">
            <div class="header-logo">
                <a href="/">
                    <img src="{{assetBase}}/assets/images/logo/logo.png" class="img-fluid logo" alt="logo">
                    <img src="{{assetBase}}/assets/images/logo/logo-white.png" class="img-fluid logo-white" alt="logo">
                </a>
            </div>
            <div class="main-menu-wrap">
                <div class="main-menu">
                    <div class="offcanvas-logo-wrap">
                        <div class="offcanvas-logo">
                            <a href="/">
                                <img src="{{assetBase}}/assets/images/logo/logo.png" class="logo" alt="logo">
                                <img src="{{assetBase}}/assets/images/logo/logo-white.png" class="logo-white"
                                    alt="logo">
                            </a>
                        </div>
                        <span class="menu-close-btn"><i class="bi bi-x-lg"></i></span>
                    </div>

                    <ul class="main-nav">
                        {{#each filteredSections}}
                        <li class="{{isActiveMenu this.alias}}">
                            <a href="{{this.alias}}">{{this.name}}</a>
                        </li>
                        {{/each}}
                    </ul>

                </div>
            </div>
            <div class="nav-right">
                <div class="search-btn"><a href="javascript:void(0)" class="search-open-btn"><i
                            class="icon-search"></i></a></div>
                <div class="header-cta">
                    <a class="header-cta-btn" href="tel:+12025550918">
                        <div class="cta-icon"><i class="icon-phone-ringing"></i></div>
                        <div class="cta-btn-text"><span>{{solvatechcontactcards.[0].descripcion}}</span><small>{{
                                solvatechcontact.[0].titulo_formulario }}</small></div>
                    </a>
                </div>
                <div class="offcanvas-btn mobile-menu-btn"><i class="bi bi-list sidebar-toggle-button"></i></div>
                <div class="header_hamburger sidebar_toggle">
                    <div class="header-bar">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header><!-- end .header -->